{
  "name": "brainrot-coloring-lab",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "tunnel": "set EXPO_TUNNEL_TIMEOUT=120000&& npx expo start --tunnel --clear",
    "ios": "expo run:ios",
    "dev": "npx expo start --dev-client --tunnel --clear",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "build:all": "eas build --platform all --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "release": "eas build --platform all --profile production --auto-submit",
    "postinstall": "npx patch-package"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "expo": "~54.0.6",
    "expo-asset": "~12.0.12",
    "expo-av": "~16.0.8",
    "expo-file-system": "~19.0.21",
    "expo-localization": "~17.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.577.0",
    "react": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.14.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
